rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'saea.2021.7@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // RSVP Validation
    function isValidRSVP(data) {
      return data.keys().hasAll(['guestName', 'status', 'mealChoice', 'comment', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.guestName is string && data.guestName.size() >= 2 && data.guestName.size() <= 100 &&
             data.status in ['present', 'absent'] &&
             data.mealChoice in ['perche', 'boeuf', 'none'] &&
             data.comment is string && data.comment.size() <= 500 &&
             data.createdAt == request.time;
    }

    match /rsvps/{rsvpId} {
      // Anyone can respond to the invitation
      allow create: if isValidRSVP(request.resource.data) && isValidId(rsvpId);
      
      // Dashboard now fetches without Google Auth, so we allow public read
      // WARNING: This makes the RSVP data technically public if someone knows the project ID.
      allow read: if true;
      
      // Admin verification for updates/deletes should still be handled via Admin SDK if implemented,
      // but for now we restrict it to false (client side).
      allow update, delete: if false;
    }
  }
}
