rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'saea.2021.7@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // RSVP Validation
    function isValidRSVP(data) {
      return data.keys().hasAll(['guestName', 'status', 'starterChoice', 'mealChoice', 'comment', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.guestName is string && data.guestName.size() >= 2 && data.guestName.size() <= 100 &&
             data.status in ['present', 'absent'] &&
             data.starterChoice in ['jambon', 'tomate', 'crevette', 'none'] &&
             data.mealChoice in ['perche', 'boeuf', 'none'] &&
             data.comment is string && data.comment.size() <= 500 &&
             data.createdAt == request.time;
    }

    match /rsvps/{rsvpId} {
      // Anyone can respond to the invitation
      allow create: if isValidRSVP(request.resource.data) && isValidId(rsvpId);
      
      // Dashboard now fetches without Google Auth, so we allow public read
      // WARNING: This makes the RSVP data technically public if someone knows the project ID.
      allow read: if true;
      
      // Allow deletion for cleanup
      // In a production app, this should be restricted to authenticated admins.
      // For this specific setup, we'll allow it from the dashboard.
      allow delete: if true;
      
      allow update: if false;
    }
  }
}
